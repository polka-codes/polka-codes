{
  "name": "polka-codes",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "bun --filter './packages/**' build",
    "lint": "biome check .",
    "fix": "biome check --write --unsafe",
    "check": "tsc --noEmit && biome check",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo packages/*/.tsbuildinfo packages/*/node_modules/.cache",
    "cli": "bun run --no-check packages/cli/src/index.ts",
    "release": "bun run scripts/release.ts",
    "release:publish": "bun run scripts/trigger-release.ts",
    "pr": "bun cli pr",
    "commit": "bun cli commit",
    "codegen": "cd packages/github; graphql-codegen",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@microsoft/api-extractor": "^7.58.7",
    "bun-types": "^1.3.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "bun@1.3.0",
  "dependencies": {
    "@graphql-codegen/cli": "^7.0.0"
  }
}
