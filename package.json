{
  "name": "polka-codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@graphql-codegen/core": "^6.2.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^6.1.0",
    "bun-types": "^1.3.14",
    "graphql": "^17.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2"
  },
  "license": "AGPL-3.0",
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "bun run --filter @polka-codes/core build && bun run --filter @polka-codes/cli-shared build && bun run --filter @polka-codes/github build && bun run --filter @polka-codes/runner build && bun run --filter @polka-codes/cli build",
    "lint": "biome check .",
    "fix": "biome check --write --unsafe",
    "check": "tsc --noEmit && biome check",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo packages/*/.tsbuildinfo packages/*/node_modules/.cache",
    "cli": "bun run --no-check packages/cli/src/index.ts",
    "release": "bun run scripts/release.ts",
    "release:publish": "bun run scripts/trigger-release.ts",
    "pr": "bun cli pr",
    "commit": "bun cli commit",
    "codegen": "bun run scripts/codegen.ts",
    "validate:publish": "bun run scripts/validate-publish.ts",
    "check:publish": "bun run build && bun run validate:publish",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
    "test:coverage:html": "bun test --coverage --coverage-reporter=html"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ]
}
