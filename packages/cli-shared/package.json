{
  "name": "@polka-codes/cli-shared",
  "version": "0.11.4",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/cli-shared"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && bun run ../../scripts/fix-declaration-imports.ts dist && bun build src/index.ts --outdir dist --target node --format esm --packages external --tsconfig-override=../../tsconfig.bundle.json --external=@polka-codes/core && bun run build:copy-wasm",
    "build:copy-wasm": "mkdir -p dist && cp node_modules/sql.js/dist/sql-wasm.wasm dist/"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^5.0.20",
    "@ai-sdk/provider": "^4.0.3",
    "@inquirer/prompts": "^8.5.2",
    "@polka-codes/core": "^0.11.4",
    "ai": "^7.0.28",
    "chalk": "^5.6.2",
    "ignore": "^7.0.6",
    "lodash-es": "^4.18.1",
    "mime-types": "^3.0.2",
    "sql.js": "^1.14.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/mime-types": "^3.0.1",
    "@types/sql.js": "^1.4.11"
  }
}
