{
  "name": "@polka-codes/core",
  "version": "0.11.4",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/core"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && bun run ../../scripts/fix-declaration-imports.ts dist && bun build src/index.ts --outdir dist --target node --format esm --packages external"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.3",
    "@ai-sdk/provider-utils": "^5.0.10",
    "ai": "^7.0.28",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
