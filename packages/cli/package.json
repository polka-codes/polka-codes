{
  "name": "@polka-codes/cli",
  "version": "0.11.2",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "polka": "dist/bin.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && bun run ../../scripts/fix-declaration-imports.ts dist && bun build src/index.ts --outfile dist/index.js --target node --format esm --packages external --tsconfig-override=../../tsconfig.bundle.json --external=@polka-codes/core --external=@polka-codes/cli-shared && bun build src/bin.ts --outfile dist/bin.cjs --target node --format cjs --banner '#!/usr/bin/env node' && bun run build:copy-wasm",
    "build:copy-wasm": "mkdir -p dist && cp ../cli-shared/node_modules/sql.js/dist/sql-wasm.wasm dist/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/deepseek": "^3.0.11",
    "@ai-sdk/google": "^4.0.16",
    "@ai-sdk/google-vertex": "^5.0.20",
    "@ai-sdk/openai": "^4.0.14",
    "@ai-sdk/openai-compatible": "^3.0.10",
    "@ai-sdk/provider": "^4.0.3",
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@polka-codes/cli-shared": "^0.11.2",
    "@polka-codes/core": "^0.11.2",
    "ai": "^7.0.28",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "lodash-es": "^4.18.1",
    "mime-types": "^3.0.2",
    "ora": "^9.4.1",
    "ulid": "^3.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/mime-types": "^3.0.1"
  }
}
