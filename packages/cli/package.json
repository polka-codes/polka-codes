{
  "name": "@polka-codes/cli",
  "version": "0.10.16",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "polka": "cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build --force && tsup src/index.ts --format esm && bun run build:copy-wasm",
    "build:copy-wasm": "mkdir -p dist && cp ../../node_modules/sql.js/dist/sql-wasm.wasm dist/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/google-vertex": "^4.0.98",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.21",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@polka-codes/cli-shared": "^0.10.16",
    "@polka-codes/core": "^0.10.16",
    "ai": "^6.0.142",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^17.3.1",
    "lodash-es": "^4.17.23",
    "mime-types": "^3.0.2",
    "ora": "^9.3.0",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "files": [
    "dist",
    "cli.mjs"
  ],
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/mime-types": "^3.0.1"
  }
}
