{
  "name": "@polka-codes/github",
  "version": "0.12.0",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/github"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && bun run ../../scripts/fix-declaration-imports.ts dist && bun build src/index.ts --outdir dist --target node --format esm --packages external --loader .gql:text"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4"
  }
}
