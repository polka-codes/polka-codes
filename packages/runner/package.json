{
  "name": "@polka-codes/runner",
  "version": "0.11.4",
  "license": "AGPL-3.0",
  "author": "github@polka.codes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polka-codes/polka-codes.git",
    "directory": "packages/runner"
  },
  "type": "module",
  "bin": {
    "polka-runner": "cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --build --force && bun run ../../scripts/fix-declaration-imports.ts dist && bun build src/index.ts src/cli.ts --outdir dist --target node --format esm --packages external --tsconfig-override=../../tsconfig.bundle.json --external=@polka-codes/core --external=@polka-codes/cli-shared"
  },
  "dependencies": {
    "@polka-codes/cli-shared": "^0.11.4",
    "@polka-codes/core": "^0.11.4",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "files": [
    "dist",
    "cli.mjs"
  ],
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "yaml": "^2.9.0"
  }
}
